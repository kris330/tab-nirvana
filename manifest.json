{
  "manifest_version": 3,
  "name": "TabNirvana",
  "version": "1.1.0",
  "description": "Aggregate, manage, and obliterate your tabs with satisfying precision.",
  "permissions": ["tabs", "windows", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "content_scripts/extractor.js",
        "content_scripts/floating-btn.js"
      ],
      "css": ["content_scripts/floating-btn.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["summary/index.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+V",
        "mac": "Alt+V"
      },
      "description": "Open TabNirvana"
    }
  },
  "action": {
    "default_title": "Open TabNirvana",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
